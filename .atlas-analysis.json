  "keyFeatures": [
    "Real-time order management with Supabase Realtime",
    "Kanban board for order workflow (pending → kitchen → delivery → completed)",
    "Live dashboard with sales analytics and peak hours visualization",
    "WhatsApp integration via webhooks (N8N/Make/Zapier)",
    "Order history with filtering by payment method and date range",
    "Authentication with Supabase Auth",
    "Real-time notifications for new orders and status changes"
  ],
  "publicApiSurface": [
    "getPedidosActivos() - Fetch active orders for Kanban board",
    "getPedidosHistorial() - Fetch order history with filters",
    "updateEstadoPedido() - Update order status in workflow",
    "cancelarPedido() - Cancel an order",
    "getStatsDashboard() - Fetch data for dashboard analytics",
    "calcularStats() - Calculate KPIs from order data",
    "usePedidosRealtime() - Hook for real-time order synchronization",
    "useDashboard() - Hook for dashboard statistics",
    "usePlatos() - Hook for menu items management",
    "AuthContext - Authentication state management",
    "NotificationsContext - Real-time notification system"
  ]
}
